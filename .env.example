# LLM 模型配置
# 请根据实际使用的模型提供商填写以下配置
# 复制本文件为 .env 后修改

# ---- API 配置 ----
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://your-base-url-here/v1

# ---- 可选配置 ----
# TAVILY_API_KEY=your-tavily-api-key
# QWEATHER_API_HOST=your-qweather-host
# PROJECT_ID=your-project-id
# KEY_ID=your-key-id

# ---- 代理配置（默认不使用） ----
# LLM_HTTP_PROXY=http://127.0.0.1:7890
# LLM_HTTPS_PROXY=http://127.0.0.1:7890